{
  "title": "北京市海淀区小学绿地空间分析与规划设计建议 - 交互逻辑",
  "version": "1.0",
  "pages": {
    "home": {
      "name": "首页",
      "options": [
        {"label": "数据仪表板", "target": "dashboard"},
        {"label": "规划设计建议", "target": "planning"}
      ]
    },
    "dashboard": {
      "name": "数据仪表板",
      "features": [
        "筛选器：所属类别、500m内公园、最近公园距离、排序",
        "KPI卡片：学校数、公园占比、平均距离、平均绿地率",
        "可展开表格：点击展开显示6张卫星图",
        "查看统计分析按钮 → #analysis"
      ],
      "sub_pages": {
        "charts": {"name": "交互式图表（ECharts）", "back": "dashboard"},
        "analysis": {
          "name": "统计分析（5张图表+分析文字）",
          "back": "dashboard",
          "features": ["图表已嵌入base64", "底部返回数据按钮"]
        }
      }
    },
    "planning": {
      "name": "规划设计建议",
      "first_choice": {
        "question": "学校周围500m范围内是否有公园？",
        "options": [
          {
            "label": "有",
            "shows": ["校内改造方案", "通学路径改造方案", "公园改造方案"]
          },
          {
            "label": "无",
            "shows": ["校内改造方案", "通学路径改造方案"]
          }
        ]
      },
      "sub_modules": {
        "校内改造方案": {
          "type": "external_html",
          "file": "校内改造方案.html",
          "features": [
            "3步问卷：绿地覆盖率→楼层高度→降水条件",
            "根据选择推荐改造部位和措施",
            "底部：返回规划设计建议 / 重新选择校园状况"
          ]
        },
        "通学路径改造方案": {
          "type": "embedded_page",
          "hash": "#commute",
          "features": [
            "6大类场景：道路空间、道路边界、交通环境、周边业态、绿化设施、特殊场景",
            "每类4-5个条件选择",
            "29项具体改造措施，含案例和参考文献",
            "图片灯箱预览"
          ],
          "data_source": "校外改造措施-结构化.json"
        },
        "公园改造方案": {
          "type": "embedded_page",
          "hash": "#park-design",
          "features": [
            "核心目标：增加自然吸引力与挑战性",
            "必要性分析",
            "设计逻辑",
            "具体设计：植物游戏、活动区、自然教育空间",
            "案例：德国Egapark、淄博西五路Linear Park",
            "可展开/收起的accordion"
          ],
          "data_source": "公园规划-设计.docx"
        }
      }
    }
  },
  "file_structure": {
    "【main】北京市海淀区小学绿地空间分析与规划建议.html": "主HTML文件（所有页面）",
    "校内改造方案.html": "校内改造方案（独立HTML）",
    "学校详情图/": "156所学校×6张卫星图",
    "校内设计图/": "校内改造参考图片（53张）",
    "通学设计图/": "通学路径类别和条件图片（31张）",
    "通学道路设计图/": "通学路径改造措施图片（25张）",
    "公园设计图/": "公园规划图片（10张，从docx提取）",
    "charts/": "统计分析图表（5张）"
  }
}
