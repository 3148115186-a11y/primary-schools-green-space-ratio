@echo off
chcp 65001 >nul
echo =========================================
echo   海淀小学绿地覆盖分析 - 启动脚本
echo =========================================
echo.

:: =============================================
:: 在这里填入你的 DASHSCOPE_API_KEY
:: =============================================
set DASHSCOPE_API_KEY=sk-在这里填入你的APIKey

:: 检查 Key 是否已填写
if "%DASHSCOPE_API_KEY%"=="sk-在这里填入你的APIKey" (
    echo [错误] 请先编辑本文件，将 DASHSCOPE_API_KEY 替换为你的真实 Key！
    echo 文件位置: %~f0
    pause
    exit /b 1
)

echo API Key: %DASHSCOPE_API_KEY:~0,8%...（已隐藏）
echo.

:: =============================================
:: 运行模式选择
:: 取消注释其中一行来切换模式：
:: =============================================

:: 【模式1】测试模式 - 只分析前3张图片，快速验证效果
:: python 分析小学绿地覆盖.py --test 3

:: 【模式2】全量分析 - 分析所有156张图片（预计约30-60分钟）
python 分析小学绿地覆盖.py

:: 【模式3】全量分析 + 自定义并发数
:: python 分析小学绿地覆盖.py --workers 2

echo.
echo 分析完成！结果文件：绿地分析结果.json
pause
